[ req ]
default_bits = 2048
default_md = sha256
prompt = no
utf8 = yes
encrypt_key = no
distinguished_name = dn
req_extensions = req_ext

[ dn ]
C = XX
O = IWCD Test
CN = ft-test-server

[ req_ext ]
subjectAltName = @my_subject_alt_names
basicConstraints = CA:FALSE
keyUsage = nonRepudiation, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectKeyIdentifier=hash

[ my_subject_alt_names ]
DNS.1 = ft-test-server
DNS.2 = ft-test-double
DNS.3 = ft-test-double-classical
DNS.4 = ft-test-double-pq-hybrid
DNS.5 = localhost
DNS.6 = *.local
IP.1 = 127.0.0.1